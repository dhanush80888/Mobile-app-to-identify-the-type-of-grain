<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/card_border"
    app:cardBackgroundColor="@color/surface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Grain Image Card Container -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_image_container"
            android:layout_width="72dp"
            android:layout_height="72dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/iv_grain_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_grain_logo"
                android:contentDescription="Grain image" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Information Container (Key-Value Grid) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/info_layout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/card_image_container"
            app:layout_constraintEnd_toStartOf="@id/btn_delete_item">

            <!-- Row 1: Grain Name -->
            <TextView
                android:id="@+id/tv_grain_name_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Grain Name:"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="normal"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tv_grain_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Rice"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp"
                app:layout_constraintTop_toTopOf="@id/tv_grain_name_label"
                app:layout_constraintBottom_toBottomOf="@id/tv_grain_name_label"
                app:layout_constraintStart_toEndOf="@id/tv_grain_name_label"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Row 2: Confidence -->
            <TextView
                android:id="@+id/tv_confidence_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confidence:"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/tv_grain_name_label"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tv_confidence"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="96%"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp"
                app:layout_constraintTop_toTopOf="@id/tv_confidence_label"
                app:layout_constraintBottom_toBottomOf="@id/tv_confidence_label"
                app:layout_constraintStart_toEndOf="@id/tv_confidence_label"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Row 3: Date -->
            <TextView
                android:id="@+id/tv_date_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date:"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/tv_confidence_label"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="June 2, 2026"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="normal"
                android:layout_marginStart="4dp"
                app:layout_constraintTop_toTopOf="@id/tv_date_label"
                app:layout_constraintBottom_toBottomOf="@id/tv_date_label"
                app:layout_constraintStart_toEndOf="@id/tv_date_label"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Row 4: Time -->
            <TextView
                android:id="@+id/tv_time_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Time:"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/tv_date_label"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tv_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="10:45 AM"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="normal"
                android:layout_marginStart="4dp"
                app:layout_constraintTop_toTopOf="@id/tv_time_label"
                app:layout_constraintBottom_toBottomOf="@id/tv_time_label"
                app:layout_constraintStart_toEndOf="@id/tv_time_label"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Delete Item Button -->
        <ImageButton
            android:id="@+id/btn_delete_item"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Delete record"
            android:padding="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
