<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Modern Material Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:background="?attr/colorPrimary"
            android:theme="@style/ThemeOverlay.MaterialComponents.ActionBar"
            app:navigationIcon="@drawable/ic_menu"
            app:navigationIconTint="@color/text_on_primary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Circular Logo Container -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/toolbar_logo_card"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surface"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_grain_logo"
                        android:padding="4dp"
                        android:contentDescription="App Logo" />
                </androidx.cardview.widget.CardView>

                <!-- Titles layout -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/toolbar_logo_card"
                    app:layout_constraintEnd_toStartOf="@id/notification_container">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Grain Classifier"
                        android:textColor="@color/text_on_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI Powered Grain Identification"
                        android:textColor="@color/text_on_primary"
                        android:alpha="0.8"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Notification Icon with green dot badge -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/notification_container"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="12dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:id="@+id/iv_notification"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_notification"
                        android:tint="@color/text_on_primary"
                        app:tint="@color/text_on_primary"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:contentDescription="Notifications" />

                    <!-- Green Dot Badge -->
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="#2ECC71"
                        android:layout_marginTop="10dp"
                        android:layout_marginEnd="10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.appbar.MaterialToolbar>

        <!-- Scrollable Main Content -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:background="@color/background"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <!-- Hero Card Section -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/hero_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/card_border"
                    app:cardBackgroundColor="@color/surface"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <!-- Left Column text/badge content -->
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/hero_left_layout"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/iv_hero_banner"
                            android:layout_marginEnd="8dp">

                            <TextView
                                android:id="@+id/tv_welcome_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Welcome to"
                                android:textColor="#2E7D32"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintStart_toStartOf="parent" />

                            <TextView
                                android:id="@+id/tv_welcome_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Grain Classifier"
                                android:textColor="@color/text_primary"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:layout_marginTop="2dp"
                                app:layout_constraintTop_toBottomOf="@id/tv_welcome_label"
                                app:layout_constraintStart_toStartOf="parent" />

                            <TextView
                                android:id="@+id/tv_welcome_desc"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:text="Identify, classify, and analyze grain types instantly using modern AI computer vision."
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:layout_marginTop="8dp"
                                app:layout_constraintTop_toBottomOf="@id/tv_welcome_title"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintEnd_toEndOf="parent" />

                            <!-- Pill badge: Accurate • Fast • Reliable -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/badge_hero"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="0dp"
                                app:strokeWidth="0dp"
                                app:cardBackgroundColor="@color/primary_light"
                                app:layout_constraintTop_toBottomOf="@id/tv_welcome_desc"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintBottom_toBottomOf="parent">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:paddingHorizontal="10dp"
                                    android:paddingVertical="4dp">

                                    <ImageView
                                        android:layout_width="14dp"
                                        android:layout_height="14dp"
                                        android:src="@drawable/ic_shield"
                                        android:tint="@color/primary"
                                        app:tint="@color/primary"
                                        android:contentDescription="Verified" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Accurate • Fast • Reliable"
                                        android:textColor="@color/primary"
                                        android:textSize="10sp"
                                        android:textStyle="bold"
                                        android:layout_marginStart="6dp" />
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>
                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <!-- Hero Image on the right -->
                        <ImageView
                            android:id="@+id/iv_hero_banner"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:src="@drawable/grain_hero_banner"
                            android:scaleType="fitCenter"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:contentDescription="Crop Illustration" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Action Cards Grid (ConstraintLayout 2x2) -->
                <!-- Take Photo Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_take_photo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/card_border"
                    app:cardBackgroundColor="@color/card_take_photo_bg"
                    app:layout_constraintTop_toBottomOf="@id/hero_card"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btn_upload_image">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/icon_container_take_photo"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/card_take_photo_icon"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_camera"
                                android:tint="@color/surface"
                                app:tint="@color/surface"
                                android:padding="10dp"
                                android:contentDescription="Camera Icon" />
                        </androidx.cardview.widget.CardView>

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_arrow_forward"
                            android:tint="@color/card_take_photo_icon"
                            app:tint="@color/card_take_photo_icon"
                            app:layout_constraintTop_toTopOf="@id/icon_container_take_photo"
                            app:layout_constraintBottom_toBottomOf="@id/icon_container_take_photo"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:contentDescription="Go" />

                        <TextView
                            android:id="@+id/tv_title_take_photo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Take Photo"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="16dp"
                            app:layout_constraintTop_toBottomOf="@id/icon_container_take_photo"
                            app:layout_constraintStart_toStartOf="parent" />

                        <TextView
                            android:id="@+id/tv_desc_take_photo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Capture grain using camera"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"
                            app:layout_constraintTop_toBottomOf="@id/tv_title_take_photo"
                            app:layout_constraintStart_toStartOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Upload Image Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_upload_image"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/card_border"
                    app:cardBackgroundColor="@color/card_upload_image_bg"
                    app:layout_constraintTop_toBottomOf="@id/hero_card"
                    app:layout_constraintStart_toEndOf="@id/btn_take_photo"
                    app:layout_constraintEnd_toEndOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/icon_container_upload"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/card_upload_image_icon"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_upload"
                                android:tint="@color/surface"
                                app:tint="@color/surface"
                                android:padding="10dp"
                                android:contentDescription="Upload Icon" />
                        </androidx.cardview.widget.CardView>

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_arrow_forward"
                            android:tint="@color/card_upload_image_icon"
                            app:tint="@color/card_upload_image_icon"
                            app:layout_constraintTop_toTopOf="@id/icon_container_upload"
                            app:layout_constraintBottom_toBottomOf="@id/icon_container_upload"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:contentDescription="Go" />

                        <TextView
                            android:id="@+id/tv_title_upload"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Upload Image"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="16dp"
                            app:layout_constraintTop_toBottomOf="@id/icon_container_upload"
                            app:layout_constraintStart_toStartOf="parent" />

                        <TextView
                            android:id="@+id/tv_desc_upload"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Choose from gallery"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"
                            app:layout_constraintTop_toBottomOf="@id/tv_title_upload"
                            app:layout_constraintStart_toStartOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Real-Time Detection Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_realtime_detection"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/card_border"
                    app:cardBackgroundColor="@color/card_realtime_bg"
                    app:layout_constraintTop_toBottomOf="@id/btn_take_photo"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btn_view_history">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/icon_container_realtime"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/card_realtime_icon"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_scan"
                                android:tint="@color/surface"
                                app:tint="@color/surface"
                                android:padding="10dp"
                                android:contentDescription="Scan Icon" />
                        </androidx.cardview.widget.CardView>

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_arrow_forward"
                            android:tint="@color/card_realtime_icon"
                            app:tint="@color/card_realtime_icon"
                            app:layout_constraintTop_toTopOf="@id/icon_container_realtime"
                            app:layout_constraintBottom_toBottomOf="@id/icon_container_realtime"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:contentDescription="Go" />

                        <TextView
                            android:id="@+id/tv_title_realtime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Real-Time Detection"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="16dp"
                            app:layout_constraintTop_toBottomOf="@id/icon_container_realtime"
                            app:layout_constraintStart_toStartOf="parent" />

                        <TextView
                            android:id="@+id/tv_desc_realtime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Detect grains in real-time"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"
                            app:layout_constraintTop_toBottomOf="@id/tv_title_realtime"
                            app:layout_constraintStart_toStartOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- View History Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_view_history"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/card_border"
                    app:cardBackgroundColor="@color/card_history_bg"
                    app:layout_constraintTop_toBottomOf="@id/btn_upload_image"
                    app:layout_constraintStart_toEndOf="@id/btn_realtime_detection"
                    app:layout_constraintEnd_toEndOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/icon_container_history"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/card_history_icon"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_history"
                                android:tint="@color/surface"
                                app:tint="@color/surface"
                                android:padding="10dp"
                                android:contentDescription="History Icon" />
                        </androidx.cardview.widget.CardView>

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_arrow_forward"
                            android:tint="@color/card_history_icon"
                            app:tint="@color/card_history_icon"
                            app:layout_constraintTop_toTopOf="@id/icon_container_history"
                            app:layout_constraintBottom_toBottomOf="@id/icon_container_history"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:contentDescription="Go" />

                        <TextView
                            android:id="@+id/tv_title_history"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="View History"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="16dp"
                            app:layout_constraintTop_toBottomOf="@id/icon_container_history"
                            app:layout_constraintStart_toStartOf="parent" />

                        <TextView
                            android:id="@+id/tv_desc_history"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="See your recent classifications"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"
                            app:layout_constraintTop_toBottomOf="@id/tv_title_history"
                            app:layout_constraintStart_toStartOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Supported Grains Section -->
                <TextView
                    android:id="@+id/tv_section_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Supported Grains"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="24dp"
                    app:layout_constraintTop_toBottomOf="@id/btn_realtime_detection"
                    app:layout_constraintStart_toStartOf="parent" />

                <LinearLayout
                    android:id="@+id/layout_view_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintTop_toTopOf="@id/tv_section_title"
                    app:layout_constraintBottom_toBottomOf="@id/tv_section_title"
                    app:layout_constraintEnd_toEndOf="parent">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View All"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_arrow_forward"
                        android:tint="@color/primary"
                        app:tint="@color/primary"
                        android:layout_marginStart="2dp"
                        android:contentDescription="Arrow" />
                </LinearLayout>

                <!-- Horizontal RecyclerView for Supported Grains -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_supported_grains"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_supported_grain"
                    app:layout_constraintTop_toBottomOf="@id/tv_section_title"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Bottom Features Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_features"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/card_border"
                    app:cardBackgroundColor="@color/feature_layout_bg"
                    app:layout_constraintTop_toBottomOf="@id/rv_supported_grains"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:baselineAligned="false">

                        <!-- Feature 1: Offline -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="4dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_shield"
                                android:tint="@color/primary"
                                app:tint="@color/primary"
                                android:contentDescription="Shield" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="100% Offline"
                                    android:textColor="@color/text_primary"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Works without net"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="8sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/card_border"
                            android:layout_marginVertical="4dp"/>

                        <!-- Feature 2: High Accuracy -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="4dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_target"
                                android:tint="@color/primary"
                                app:tint="@color/primary"
                                android:contentDescription="Target" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="High Accuracy"
                                    android:textColor="@color/text_primary"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="AI model precision"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="8sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/card_border"
                            android:layout_marginVertical="4dp"/>

                        <!-- Feature 3: Instant Results -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="4dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_bolt"
                                android:tint="@color/primary"
                                app:tint="@color/primary"
                                android:contentDescription="Bolt" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Instant Results"
                                    android:textColor="@color/text_primary"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Results in seconds"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="8sp" />
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Drawer View -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
