<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Header Card Section -->
        <androidx.cardview.widget.CardView
            android:id="@+id/header_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/surface"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/iv_mini_logo"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_grain_logo"
                    android:contentDescription="@string/app_name"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tv_welcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_welcome"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginStart="12dp"
                    app:layout_constraintTop_toTopOf="@id/iv_mini_logo"
                    app:layout_constraintStart_toEndOf="@id/iv_mini_logo" />

                <TextView
                    android:id="@+id/tv_main_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_welcome"
                    app:layout_constraintStart_toEndOf="@id/iv_mini_logo" />

                <TextView
                    android:id="@+id/tv_tagline"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/home_tagline"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.2"
                    android:layout_marginTop="16dp"
                    app:layout_constraintTop_toBottomOf="@id/iv_mini_logo"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- Actions Panel: Photo and Upload Buttons -->
        <TextView
            android:id="@+id/tv_action_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analyze Crops"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/header_card"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Take Photo Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_take_photo"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="@string/btn_take_photo"
            android:textColor="@color/text_on_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_camera"
            app:iconTint="@color/text_on_primary"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/primary"
            app:elevation="4dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="6dp"
            app:layout_constraintTop_toBottomOf="@id/tv_action_header"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_upload_image" />

        <!-- Upload Image Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_upload_image"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="@string/btn_upload_image"
            android:textColor="@color/text_on_secondary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_upload"
            app:iconTint="@color/text_on_secondary"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/secondary"
            app:elevation="4dp"
            android:layout_marginTop="12dp"
            android:layout_marginStart="6dp"
            app:layout_constraintTop_toBottomOf="@id/tv_action_header"
            app:layout_constraintStart_toEndOf="@id/btn_take_photo"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Real-Time Detection Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_realtime_detection"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="Real-Time Detection"
            android:textColor="@color/text_on_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_scan"
            app:iconTint="@color/text_on_primary"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/primary_variant"
            app:elevation="4dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/btn_take_photo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- View History Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_view_history"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="View History"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:strokeColor="@color/primary"
            app:strokeWidth="1.5dp"
            app:cornerRadius="12dp"
            app:elevation="0dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/btn_realtime_detection"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Grains Grid Section Title -->
        <TextView
            android:id="@+id/tv_section_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_supported_grains"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/btn_view_history"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_section_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap any grain to learn more about its grading standards"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/tv_section_title"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Grain 1: Rice -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_rice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/card_border"
            app:cardBackgroundColor="@color/rice_bg"
            app:layout_constraintTop_toBottomOf="@id/tv_section_subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <!-- Bubble badge with initials -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/badge_rice"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/rice_tag"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="Ri"
                        android:gravity="center"
                        android:textColor="@color/surface"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tv_rice_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/grain_rice"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="16dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/badge_rice" />

                <TextView
                    android:id="@+id/tv_rice_desc"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/desc_rice"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="16dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_rice_title"
                    app:layout_constraintStart_toEndOf="@id/badge_rice"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Grain 2: Wheat -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_wheat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/card_border"
            app:cardBackgroundColor="@color/wheat_bg"
            app:layout_constraintTop_toBottomOf="@id/card_rice"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <!-- Bubble badge with initials -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/badge_wheat"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/wheat_tag"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="Wh"
                        android:gravity="center"
                        android:textColor="@color/surface"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tv_wheat_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/grain_wheat"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="16dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/badge_wheat" />

                <TextView
                    android:id="@+id/tv_wheat_desc"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/desc_wheat"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="16dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_wheat_title"
                    app:layout_constraintStart_toEndOf="@id/badge_wheat"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Grain 3: Maize -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_maize"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/card_border"
            app:cardBackgroundColor="@color/maize_bg"
            app:layout_constraintTop_toBottomOf="@id/card_wheat"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <!-- Bubble badge with initials -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/badge_maize"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/maize_tag"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="Mz"
                        android:gravity="center"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tv_maize_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/grain_maize"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="16dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/badge_maize" />

                <TextView
                    android:id="@+id/tv_maize_desc"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/desc_maize"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="16dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_maize_title"
                    app:layout_constraintStart_toEndOf="@id/badge_maize"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Grain 4: Bajra -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_bajra"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/card_border"
            app:cardBackgroundColor="@color/bajra_bg"
            app:layout_constraintTop_toBottomOf="@id/card_maize"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <!-- Bubble badge with initials -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/badge_bajra"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/bajra_tag"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="Bj"
                        android:gravity="center"
                        android:textColor="@color/surface"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tv_bajra_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/grain_bajra"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="16dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/badge_bajra" />

                <TextView
                    android:id="@+id/tv_bajra_desc"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/desc_bajra"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="16dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_bajra_title"
                    app:layout_constraintStart_toEndOf="@id/badge_bajra"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Grain 5: Ragi -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_ragi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/card_border"
            app:cardBackgroundColor="@color/ragi_bg"
            app:layout_constraintTop_toBottomOf="@id/card_bajra"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <!-- Bubble badge with initials -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/badge_ragi"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/ragi_tag"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="Rg"
                        android:gravity="center"
                        android:textColor="@color/surface"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tv_ragi_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/grain_ragi"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="16dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/badge_ragi" />

                <TextView
                    android:id="@+id/tv_ragi_desc"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/desc_ragi"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="16dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_ragi_title"
                    app:layout_constraintStart_toEndOf="@id/badge_ragi"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
