<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    tools:context=".RealTimeDetectionActivity">

    <!-- CameraX PreviewView -->
    <androidx.camera.view.PreviewView
        android:id="@+id/view_finder"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Dark Semi-transparent Overlay for view masking -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#26000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Animated Viewfinder Scanner Reticle in Center -->
    <ImageView
        android:id="@+id/iv_viewfinder"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:src="@drawable/ic_scan"
        android:contentDescription="Viewfinder"
        android:alpha="0.8"
        app:tint="@color/primary_light"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scanning line animator indicator -->
    <View
        android:id="@+id/scan_bar"
        android:layout_width="200dp"
        android:layout_height="2dp"
        android:background="@color/primary_light"
        app:layout_constraintTop_toTopOf="@id/iv_viewfinder"
        app:layout_constraintBottom_toBottomOf="@id/iv_viewfinder"
        app:layout_constraintStart_toStartOf="@id/iv_viewfinder"
        app:layout_constraintEnd_toEndOf="@id/iv_viewfinder" />

    <!-- Top floating back button and header -->
    <androidx.cardview.widget.CardView
        android:id="@+id/btn_back_container"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#CCFFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            android:scaleType="centerInside"
            android:padding="8dp"
            app:tint="@color/text_primary" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Real-Time Scanner"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:shadowColor="#80000000"
        android:shadowRadius="8"
        android:shadowDx="0"
        android:shadowDy="2"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="@id/btn_back_container"
        app:layout_constraintBottom_toBottomOf="@id/btn_back_container"
        app:layout_constraintStart_toEndOf="@id/btn_back_container" />

    <!-- Results Panel at bottom -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_results"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#FDFDFD"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- Scanning Status Indicator -->
            <androidx.cardview.widget.CardView
                android:id="@+id/badge_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bajra_bg"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent">
                
                <TextView
                    android:id="@+id/tv_status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Initializing Model..."
                    android:textColor="@color/primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp" />
            </androidx.cardview.widget.CardView>

            <!-- Detected Grain Name Header -->
            <TextView
                android:id="@+id/tv_detected_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detected Grain"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.05"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/badge_status"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Prediction Label -->
            <TextView
                android:id="@+id/tv_grain_class"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Scanning..."
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/tv_detected_title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tv_confidence_percent" />

            <!-- Confidence Percent value -->
            <TextView
                android:id="@+id/tv_confidence_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textColor="@color/primary"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/tv_grain_class"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Progress bar overlay wrapper -->
            <ProgressBar
                android:id="@+id/progress_confidence"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@android:drawable/progress_horizontal"
                android:progressTint="@color/primary"
                android:progressBackgroundTint="@color/card_border"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/tv_grain_class"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tv_helper_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Hold camera steady. Results are stabilized dynamically."
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/progress_confidence"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
