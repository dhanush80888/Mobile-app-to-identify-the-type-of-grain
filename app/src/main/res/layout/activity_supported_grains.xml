<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".SupportedGrainsActivity">

    <!-- Header / Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:minHeight="?attr/actionBarSize"
        android:theme="@style/ThemeOverlay.MaterialComponents.ActionBar"
        app:title="Supported Grains"
        app:titleTextColor="@color/text_on_primary"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/text_on_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Classification Standards"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="The model is trained on these 5 major grain categories and evaluates their physical quality grades."
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/tv_title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Grain Cards list container -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- 1. Rice Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/card_border"
                    app:cardBackgroundColor="@color/rice_bg">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rice (Oryza sativa)"
                            android:textColor="@color/rice_tag"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="• Classification standard: Long / Medium / Short Grain\n• Target Moisture Threshold: &lt; 14.0%\n• Average Length: 5.5mm - 7.5mm\n• Quality Parameters Evaluated: Chalkiness index, head rice yield (HRY), broken ratio."
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.2"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 2. Wheat Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/card_border"
                    app:cardBackgroundColor="@color/wheat_bg">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wheat (Triticum)"
                            android:textColor="@color/wheat_tag"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="• Classification standard: Hard Red Winter / Soft White / Durum\n• Target Moisture Threshold: 12.0% - 13.5%\n• Average Length: 6.0mm - 8.0mm\n• Quality Parameters Evaluated: Hectoliter weight, gluten index, foreign matter."
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.2"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 3. Maize Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/card_border"
                    app:cardBackgroundColor="@color/maize_bg">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Maize (Zea mays)"
                            android:textColor="@color/maize_tag"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="• Classification standard: Yellow Dent / Sweet Corn / Flint Corn\n• Target Moisture Threshold: &lt; 15.0%\n• Average Diameter: 8.0mm - 10.0mm\n• Quality Parameters Evaluated: Aflatoxin PPM ratio, thermal damage ratio, cracked kernel index."
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.2"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 4. Bajra Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/card_border"
                    app:cardBackgroundColor="@color/bajra_bg">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bajra (Pennisetum glaucum)"
                            android:textColor="@color/bajra_tag"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="• Classification standard: Pearl Millet Hybrid / Desi Bajra\n• Target Moisture Threshold: &lt; 12.0%\n• Average Diameter: 2.0mm - 3.0mm\n• Quality Parameters Evaluated: Ergot density percentage, immature green kernels, viability."
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.2"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 5. Ragi Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/card_border"
                    app:cardBackgroundColor="@color/ragi_bg">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ragi (Eleusine coracana)"
                            android:textColor="@color/ragi_tag"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="• Classification standard: Finger Millet (Organic Brown / Crimson red)\n• Target Moisture Threshold: &lt; 11.0%\n• Average Seed Diameter: 1.5mm - 2.0mm\n• Quality Parameters Evaluated: Calcium concentration grade, husk retention factor, dust admixture."
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.2"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
