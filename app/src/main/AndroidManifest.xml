<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions for Image capturing and storage selection -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_grain_logo"
        android:roundIcon="@drawable/ic_grain_logo"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.GrainClassifier"
        tools:targetApi="31">
        
        <!-- Splash Screen Activity (Launcher Entry Point) -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:noHistory="true"
            android:theme="@style/Theme.GrainClassifier">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main Home Screen Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@style/Theme.GrainClassifier" />

        <!-- Prediction Screen Activity -->
        <activity
            android:name=".PredictionActivity"
            android:exported="false"
            android:theme="@style/Theme.GrainClassifier" />

        <!-- Result Screen Activity -->
        <activity
            android:name=".ResultActivity"
            android:exported="false"
            android:theme="@style/Theme.GrainClassifier" />

        <!-- Real-Time Detection Activity -->
        <activity
            android:name=".RealTimeDetectionActivity"
            android:exported="false"
            android:theme="@style/Theme.GrainClassifier" />

        <!-- History Screen Activity -->
        <activity
            android:name=".HistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.GrainClassifier" />

        <!-- Supported Grains Screen Activity -->
        <activity
            android:name=".SupportedGrainsActivity"
            android:exported="false"
            android:theme="@style/Theme.GrainClassifier" />

        <!-- Saved Results Screen Activity -->
        <activity
            android:name=".SavedResultsActivity"
            android:exported="false"
            android:theme="@style/Theme.GrainClassifier" />

        <!-- FileProvider for Secure Camera Image Sharing -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.example.grainclassifier.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
